{
  "version": "0.0.1",
  "description": "Perfiles base de configuración VR para simracing",
  "profiles": [
    {
      "id": "max_quality",
      "name": "Máxima calidad",
      "description": "Prioriza calidad visual sobre rendimiento.",
      "steamvr": {
        "resolutionPerEye": 1.5,
        "motionSmoothing": true,
        "refreshRate": 90
      },
      "openxr": {
        "preferredRuntime": "steamvr"
      },
      "odt": {
        "bitrateMbps": 250,
        "adaptiveGpuScale": true,
        "fovTangent": 0,
        "encoderResolution": 1.0
      },
      "game": {
        "launchArgs": "-vr"
      }
    },

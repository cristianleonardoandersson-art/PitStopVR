<Window x:Class="PitStopVR.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Configuración" Height="360" Width="560" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configuración de recolección real" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

        <TextBlock Grid.Row="1" Text="Ruta de adb.exe (para Meta Quest / OVR Metrics Tool):" Margin="0,0,0,4"/>
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="AdbPathTextBox" Grid.Column="0" Padding="4" Margin="0,0,8,0"/>
            <Button x:Name="BrowseAdbButton" Grid.Column="1" Content="Buscar..." Padding="10,4" Click="BrowseAdbButton_Click"/>
        </Grid>

        <TextBlock Grid.Row="3" Text="Ruta de openvr_api.dll (SteamVR), si no está en una ubicación estándar:" Margin="0,0,0,4"/>
        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="SteamVRPathTextBox" Grid.Column="0" Padding="4" Margin="0,0,8,0"/>
            <Button x:Name="BrowseSteamVRButton" Grid.Column="1" Content="Buscar..." Padding="10,4" Click="BrowseSteamVRButton_Click"/>
        </Grid>

        <Grid Grid.Row="5" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Duración mínima de sesión (segundos):" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="MinSessionSecondsTextBox" Grid.Column="1" Width="80" HorizontalAlignment="Left" Padding="4"/>
        </Grid>

        <StackPanel Grid.Row="6" Orientation="Vertical" VerticalAlignment="Top">
            <CheckBox x:Name="PreferOpenVRCheckBox" Content="Usar OpenVR/SteamVR cuando esté disponible" Margin="0,0,0,8"/>
            <CheckBox x:Name="PreferOVRMetricsToolCheckBox" Content="Usar OVR Metrics Tool (Quest) cuando esté disponible"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="CancelButton" Content="Cancelar" Padding="14,6" Click="CancelButton_Click" Margin="0,0,8,0"/>
            <Button x:Name="SaveButton" Content="Guardar" Padding="14,6" Click="SaveButton_Click" Background="Green" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>

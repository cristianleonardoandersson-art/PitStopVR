<Window x:Class="PitStopVR.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PitStopVR.App"
        mc:Ignorable="d"
        Title="PitStop VR" Height="650" Width="950">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="PitStop VR" FontSize="24" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="Administrador inteligente del ecosistema VR para simracing" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Perfil:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox x:Name="ProfileComboBox" Width="200" Margin="0,0,16,0"/>
            <CheckBox x:Name="SimulationCheckBox" Content="Modo simulación (no modifica archivos)" IsChecked="True" VerticalAlignment="Center"/>
        </StackPanel>

        <DataGrid Grid.Row="3" x:Name="GamesDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,16">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                <DataGridTextColumn Header="Juego" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Fuente" Binding="{Binding Source}" Width="80"/>
                <DataGridTextColumn Header="Ruta" Binding="{Binding InstallDir}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="4" Orientation="Vertical" HorizontalAlignment="Right">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                <Button x:Name="InspectButton" Content="Escanear PC real" Padding="12,6" Click="InspectButton_Click" Margin="0,0,8,0"/>
                <Button x:Name="SimulateButton" Content="Cargar simulación" Padding="12,6" Click="SimulateButton_Click" Background="Orange" Foreground="Black" Margin="0,0,8,0"/>
                <Button x:Name="RestoreBackupsButton" Content="Restaurar backups" Padding="12,6" Click="RestoreBackupsButton_Click" Margin="0,0,8,0"/>
                <Button x:Name="HistoryButton" Content="Ver historial" Padding="12,6" Click="HistoryButton_Click" Margin="0,0,8,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="EcosystemButton" Content="Verificar ecosistema" Padding="12,6" Click="EcosystemButton_Click" Margin="0,0,8,0"/>
                <Button x:Name="SettingsButton" Content="Configuración" Padding="12,6" Click="SettingsButton_Click" Margin="0,0,8,0"/>
                <Button x:Name="ApplyButton" Content="Aplicar perfil y lanzar" Padding="12,6" Click="ApplyButton_Click" Background="Green" Foreground="White"/>
                <Button x:Name="EndSessionButton" Content="Finalizar sesión de análisis" Padding="12,6" Click="EndSessionButton_Click" Background="DarkOrange" Foreground="White" Visibility="Collapsed" Margin="0,0,8,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>

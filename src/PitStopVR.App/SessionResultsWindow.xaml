<Window x:Class="PitStopVR.App.SessionResultsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        Title="Resultados de la sesión" Height="620" Width="780" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeaderTextBlock" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" x:Name="SubHeaderTextBlock" Margin="0,0,0,12" Foreground="Gray"/>

        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" Margin="0,0,0,12">
            <Canvas x:Name="FpsChartCanvas" Background="#FFF7F7F7" SizeChanged="FpsChartCanvas_SizeChanged"/>
        </Border>

        <TextBlock Grid.Row="3" Text="FPS estimado a lo largo de la sesión" HorizontalAlignment="Center" Foreground="Gray" Margin="0,0,0,12"/>

        <Grid Grid.Row="4" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                <TextBlock Text="Resumen de rendimiento" FontWeight="Bold" Margin="0,0,0,6"/>
                <TextBlock x:Name="StatsTextBlock" TextWrapping="Wrap"/>
            </StackPanel>

            <Border Grid.Column="1" x:Name="BottleneckBorder" CornerRadius="6" Padding="12" Background="#FFEFEFEF">
                <StackPanel>
                    <TextBlock x:Name="BottleneckTitleTextBlock" FontWeight="Bold" FontSize="15" Margin="0,0,0,6"/>
                    <TextBlock x:Name="BottleneckRecommendationTextBlock" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ExportButton" Content="Exportar" Padding="14,6" Click="ExportButton_Click" Margin="0,0,8,0"/>
            <Button x:Name="CloseButton" Content="Cerrar" Padding="14,6" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>

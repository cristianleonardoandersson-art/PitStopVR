<Window x:Class="PitStopVR.App.RestoreWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PitStopVR.App"
        mc:Ignorable="d"
        Title="Restaurar backups" Height="500" Width="750" WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Restaurar backups" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
        <TextBlock Grid.Row="1" Text="Selecciona una sesion de backup para revertir los cambios aplicados a SteamVR, OpenXR u Oculus Debug Tool." Margin="0,0,0,12" TextWrapping="Wrap"/>

        <DataGrid Grid.Row="2" x:Name="SessionsDataGrid" AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,12" SelectionChanged="SessionsDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Fecha" Binding="{Binding Timestamp}" Width="150"/>
                <DataGridTextColumn Header="Perfil" Binding="{Binding ProfileName}" Width="120"/>
                <DataGridTextColumn Header="Juego" Binding="{Binding GameName}" Width="150"/>
                <DataGridTextColumn Header="Modo" Binding="{Binding ModeLabel}" Width="80"/>
                <DataGridTextColumn Header="Componentes" Binding="{Binding Entries.Count}" Width="90"/>
                <DataGridTextColumn Header="Carpeta" Binding="{Binding SessionPath}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="RefreshButton" Content="Actualizar" Padding="12,6" Click="RefreshButton_Click" Margin="0,0,8,0"/>
            <Button x:Name="RestoreButton" Content="Restaurar seleccionado" Padding="12,6" Click="RestoreButton_Click" Background="Green" Foreground="White" IsEnabled="False"/>
        </StackPanel>
    </Grid>
</Window>
